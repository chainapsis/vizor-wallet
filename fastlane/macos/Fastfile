fastlane_version "2.220.0"

default_platform(:mac)

require "fileutils"
require "json"
require "net/http"
require "shellwords"
require "tempfile"
require "tmpdir"
require "uri"
require "yaml"
require "open3"
require_relative "../patches/developer_id_application_certificate_type_patch"

def shell_escape(value)
  Shellwords.escape(value)
end

def workspace_root
  File.expand_path("../..", __dir__)
end

def release_version_from_tag(tag)
  match = /\Arelease\/v(\d+\.\d+\.\d+)\z/.match(tag.to_s)
  UI.user_error!("Unsupported release tag format: #{tag}") unless match
  match[1]
end

def release_metadata
  pubspec = YAML.safe_load(File.read(File.join(workspace_root, "pubspec.yaml")))
  version_string = pubspec.fetch("version")
  version, build_number = version_string.split("+", 2)
  tag = ENV["RELEASE_TAG"]

  if tag.to_s.empty?
    ref_type = ENV.fetch("GITHUB_REF_TYPE")
    UI.user_error!("RELEASE_TAG is required when GITHUB_REF_TYPE is not 'tag'") unless ref_type == "tag"
    tag = ENV.fetch("GITHUB_REF_NAME")
  end

  asset_version = release_version_from_tag(tag)
  UI.user_error!("pubspec version #{version} does not match release tag #{asset_version}") unless version == asset_version
  UI.user_error!("pubspec build number is required") if build_number.to_s.strip.empty?
  app_name = "Vizor"
  dist_dir = File.join(workspace_root, "dist", "macos")
  app_path = File.join(workspace_root, "build", "macos", "Build", "Products", "Release", "#{app_name}.app")

  {
    app_name: app_name,
    bundle_id: "com.keplr.vizor",
    version: version,
    build_number: build_number,
    tag: tag,
    release_name: ENV["RELEASE_NAME"] || tag,
    dist_dir: dist_dir,
    sparkle_dir: File.join(dist_dir, "sparkle"),
    app_path: app_path,
    zip_path: File.join(dist_dir, "#{app_name}-#{asset_version}-macos.zip"),
    dmg_path: File.join(dist_dir, "#{app_name}-#{asset_version}-macos.dmg"),
    appcast_path: File.join(dist_dir, "sparkle", "appcast.xml"),
    sparkle_release_notes_path: File.join(dist_dir, "sparkle", "#{app_name}-#{asset_version}-macos.md")
  }
end

def release_boolean_env(key)
  ENV[key].to_s.downcase == "true"
end

def match_readonly?
  release_boolean_env("MATCH_READONLY")
end

def match_git_branch
  branch = ENV["MATCH_GIT_BRANCH"].to_s.strip
  branch.empty? ? "main" : branch
end

def signing_keychain_name
  keychain_name = ENV.fetch("MACOS_KEYCHAIN_NAME", "").strip
  keychain_name = "fastlane-signing.keychain-db" if keychain_name.empty?
  keychain_name
end

def signing_keychain_path
  File.expand_path(File.join("~/Library/Keychains", signing_keychain_name))
end

def match_certificate_password
  ENV.fetch("MATCH_CERTIFICATE_PASSWORD")
end

def sparkle_enabled_for_release?
  !release_boolean_env("GITHUB_RELEASE_DRAFT") && !release_boolean_env("GITHUB_RELEASE_PRERELEASE")
end

def sparkle_private_ed_key
  ENV.fetch("SPARKLE_PRIVATE_ED_KEY")
end

def github_release_page_url(metadata)
  "https://github.com/#{ENV.fetch("RELEASE_REPOSITORY")}/releases/tag/#{metadata[:tag]}"
end

def github_release_download_base_url(metadata)
  "https://github.com/#{ENV.fetch("RELEASE_REPOSITORY")}/releases/download/#{metadata[:tag]}/"
end

def with_restored_file(path)
  original_contents = File.binread(path)
  yield(path)
ensure
  File.binwrite(path, original_contents) if defined?(original_contents) && original_contents
end

def configure_sparkle_info_plist!(plist_path)
  sh("/usr/bin/plutil -replace SUPublicEDKey -string #{shell_escape(ENV.fetch("SPARKLE_PUBLIC_ED_KEY", "").strip)} #{shell_escape(plist_path)}")
end

def sparkle_tool_path(tool_name)
  candidates = Dir.glob(File.expand_path("~/Library/Developer/Xcode/DerivedData/*/SourcePackages/artifacts/sparkle/Sparkle/bin/#{tool_name}"))
  tool_path = candidates.max_by { |path| File.mtime(path) }
  UI.user_error!("Could not locate Sparkle tool #{tool_name}. Resolve Swift package dependencies first.") unless tool_path
  tool_path
end

def http_get(uri, headers: {}, limit: 5)
  UI.user_error!("Too many redirects fetching #{uri}") if limit <= 0

  request = Net::HTTP::Get.new(uri)
  headers.each { |key, value| request[key] = value }

  response = Net::HTTP.start(uri.host, uri.port, use_ssl: uri.scheme == "https") do |http|
    http.request(request)
  end

  case response
  when Net::HTTPSuccess
    response.body
  when Net::HTTPRedirection
    http_get(URI(response["location"]), headers: headers, limit: limit - 1)
  else
    UI.user_error!("HTTP GET failed for #{uri}: #{response.code} #{response.message}")
  end
end

def github_api_json(url)
  JSON.parse(
    http_get(
      URI(url),
      headers: {
        "Authorization" => "Bearer #{ENV.fetch("GITHUB_TOKEN")}",
        "Accept" => "application/vnd.github+json",
        "User-Agent" => "vizor-fastlane",
        "X-GitHub-Api-Version" => "2022-11-28"
      }
    )
  )
end

def previous_release_zip_assets(metadata, limit: 5)
  releases = github_api_json("https://api.github.com/repos/#{ENV.fetch("RELEASE_REPOSITORY")}/releases?per_page=100")

  releases.filter_map do |release|
    tag_name = release["tag_name"].to_s
    next if release["draft"] || release["prerelease"] || tag_name == metadata[:tag]
    next unless tag_name.match?(/\Arelease\/v\d+\.\d+\.\d+\z/)

    asset = Array(release["assets"]).find { |candidate| candidate["name"].to_s.end_with?("-macos.zip") }
    next unless asset

    {
      tag: tag_name,
      name: asset.fetch("name"),
      download_url: asset.fetch("browser_download_url")
    }
  end.first(limit)
end

def download_previous_release_archives!(archives_dir, metadata)
  previous_release_zip_assets(metadata).each do |asset|
    destination_path = File.join(archives_dir, asset.fetch(:name))
    next if File.exist?(destination_path)

    UI.message("Downloading prior Sparkle archive #{asset.fetch(:name)} from #{asset.fetch(:tag)}")
    File.binwrite(
      destination_path,
      http_get(
        URI(asset.fetch(:download_url)),
        headers: {
          "User-Agent" => "vizor-fastlane"
        }
      )
    )
  end
end

def write_sparkle_release_notes!(notes_path, metadata)
  File.write(
    notes_path,
    <<~MARKDOWN
      # #{metadata[:release_name]}

      See the full release notes on GitHub:

      [#{metadata[:tag]}](#{github_release_page_url(metadata)})
    MARKDOWN
  )
end

def validate_sparkle_environment!
  UI.user_error!("SPARKLE_PUBLIC_ED_KEY is required for Sparkle releases") if ENV["SPARKLE_PUBLIC_ED_KEY"].to_s.strip.empty?
  UI.user_error!("SPARKLE_PRIVATE_ED_KEY is required for Sparkle releases") if ENV["SPARKLE_PRIVATE_ED_KEY"].to_s.strip.empty?
end

def generate_sparkle_appcast!(archives_dir, metadata)
  tool_path = sparkle_tool_path("generate_appcast")

  Tempfile.create(["sparkle-private-ed-key", ".txt"]) do |private_key_file|
    private_key_file.write(sparkle_private_ed_key)
    private_key_file.flush

    sh(
      [
        shell_escape(tool_path),
        "--ed-key-file", shell_escape(private_key_file.path),
        "--download-url-prefix", shell_escape(github_release_download_base_url(metadata)),
        "--release-notes-url-prefix", shell_escape(github_release_download_base_url(metadata)),
        "--full-release-notes-url", shell_escape(github_release_page_url(metadata)),
        "--link", shell_escape(github_release_page_url(metadata)),
        "--versions", shell_escape(metadata[:build_number]),
        "--maximum-versions", "1",
        "-o", shell_escape("appcast.xml"),
        shell_escape(archives_dir)
      ].join(" ")
    )
  end
end

def setup_signing_keychain
  keychain_password = ENV.fetch("MACOS_KEYCHAIN_PASSWORD")
  keychain_path = signing_keychain_path

  if File.exist?(keychain_path)
    UI.user_error!("Refusing to delete keychain directory #{keychain_path}") if File.directory?(keychain_path)
    sh("security delete-keychain #{shell_escape(keychain_path)}")
  end

  create_keychain(
    path: keychain_path,
    password: keychain_password,
    default_keychain: true,
    unlock: true,
    timeout: 21600,
    lock_when_sleeps: true,
    lock_after_timeout: true,
    add_to_search_list: true
  )

  {
    name: signing_keychain_name,
    path: keychain_path,
    password: keychain_password
  }
end

def with_app_store_connect_api_key_path(required: true)
  raw_json = ENV["APP_STORE_CONNECT_API_KEY_JSON"].to_s
  if raw_json.empty?
    UI.user_error!("APP_STORE_CONNECT_API_KEY_JSON is required") if required
    return yield(nil)
  end

  json = JSON.parse(raw_json)

  Tempfile.create(["app_store_connect_api_key", ".json"]) do |file|
    file.write(JSON.pretty_generate(json))
    file.flush
    yield(file.path)
  end
end

def find_codesigning_identities(keychain_path)
  stdout, _stderr, _status = Open3.capture3("security", "find-identity", "-v", "-p", "codesigning", keychain_path)
  stdout
end

def ensure_developer_id_identity!(keychain_path)
  identities = find_codesigning_identities(keychain_path)
  return if identities.include?('Developer ID Application: Chainapsis Inc. (SZTB68DXM4)')

  UI.user_error!("Developer ID Application identity is not available in #{keychain_path}")
end

def import_match_signing_assets!(output_dir, keychain)
  cert_path = Dir[File.join(output_dir, "*.cer")].max
  p12_path = Dir[File.join(output_dir, "*.p12")].max

  UI.user_error!("match did not export a certificate into #{output_dir}") unless cert_path
  UI.user_error!("match did not export a private key into #{output_dir}") unless p12_path

  import_certificate(
    certificate_path: cert_path,
    keychain_path: keychain[:path],
    keychain_password: keychain[:password],
    log_output: false
  )

  import_certificate(
    certificate_path: p12_path,
    certificate_password: match_certificate_password,
    certificate_format: "pkcs12",
    keychain_path: keychain[:path],
    keychain_password: keychain[:password],
    log_output: false
  )

  ensure_developer_id_identity!(keychain[:path])
end

def collect_sparkle_assets!(metadata)
  UI.user_error!("Missing ZIP archive at #{metadata[:zip_path]}") unless File.exist?(metadata[:zip_path])

  FileUtils.rm_rf(metadata[:sparkle_dir])
  FileUtils.mkdir_p(metadata[:sparkle_dir])

  Dir.mktmpdir("sparkle-archives") do |archives_dir|
    current_zip_path = File.join(archives_dir, File.basename(metadata[:zip_path]))
    release_notes_path = File.join(archives_dir, "#{File.basename(metadata[:zip_path], ".zip")}.md")

    FileUtils.cp(metadata[:zip_path], current_zip_path)
    download_previous_release_archives!(archives_dir, metadata)
    write_sparkle_release_notes!(release_notes_path, metadata)
    generate_sparkle_appcast!(archives_dir, metadata)

    FileUtils.cp(File.join(archives_dir, "appcast.xml"), metadata[:appcast_path])
    FileUtils.cp(release_notes_path, metadata[:sparkle_release_notes_path])

    Dir[File.join(archives_dir, "*.delta")].sort.each do |delta_path|
      FileUtils.cp(delta_path, File.join(metadata[:sparkle_dir], File.basename(delta_path)))
    end
  end

  [metadata[:appcast_path], metadata[:sparkle_release_notes_path], *Dir[File.join(metadata[:sparkle_dir], "*.delta")].sort]
end

platform :mac do
  private_lane :validate_signing_environment do |options|
    readonly = options.fetch(:readonly, match_readonly?)

    ENV.fetch("MATCH_GIT_URL")
    ENV.fetch("MATCH_PASSWORD")
    ENV.fetch("MATCH_CERTIFICATE_PASSWORD")
    ENV.fetch("MACOS_KEYCHAIN_PASSWORD")

    return if readonly

    UI.user_error!("APP_STORE_CONNECT_API_KEY_JSON is required when MATCH_READONLY is false") if ENV["APP_STORE_CONNECT_API_KEY_JSON"].to_s.strip.empty?
  end

  private_lane :prepare_signing do |options|
    metadata = release_metadata
    keychain = setup_signing_keychain
    readonly = options.fetch(:readonly, match_readonly?)
    validate_signing_environment(readonly: readonly)

    Dir.mktmpdir("match-signing-assets") do |output_dir|
      with_app_store_connect_api_key_path(required: !readonly) do |api_key_path|
        match_options = {
          type: "developer_id",
          app_identifier: metadata[:bundle_id],
          platform: "macos",
          readonly: readonly,
          git_branch: match_git_branch,
          team_id: "SZTB68DXM4",
          keychain_name: keychain[:name],
          keychain_password: keychain[:password],
          output_path: output_dir
        }
        match_options[:api_key_path] = api_key_path if api_key_path
        match(match_options)
      end

      import_match_signing_assets!(output_dir, keychain)
    end

    profile_name = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING].fetch(metadata[:bundle_id])
    update_code_signing_settings(
      use_automatic_signing: false,
      path: File.join(workspace_root, "macos", "Runner.xcodeproj"),
      targets: ["Runner"],
      build_configurations: ["Release"],
      sdk: "macosx*",
      team_id: "SZTB68DXM4",
      bundle_identifier: metadata[:bundle_id],
      code_sign_identity: "Developer ID Application",
      entitlements_file_path: "Runner/Release.entitlements",
      profile_name: profile_name
    )
  end

  private_lane :notarize_app_bundle do
    metadata = release_metadata
    UI.user_error!("Missing app bundle at #{metadata[:app_path]}") unless File.directory?(metadata[:app_path])

    with_app_store_connect_api_key_path do |api_key_path|
      notarize(
        package: metadata[:app_path],
        bundle_id: metadata[:bundle_id],
        api_key_path: api_key_path,
        use_notarytool: true,
        print_log: true
      )
    end

    sh("xcrun stapler staple #{shell_escape(metadata[:app_path])}")
  end

  private_lane :notarize_dmg do
    metadata = release_metadata
    UI.user_error!("Missing disk image at #{metadata[:dmg_path]}") unless File.exist?(metadata[:dmg_path])

    with_app_store_connect_api_key_path do |api_key_path|
      notarize(
        package: metadata[:dmg_path],
        bundle_id: metadata[:bundle_id],
        api_key_path: api_key_path,
        use_notarytool: true,
        print_log: true
      )
    end

    sh("xcrun stapler staple #{shell_escape(metadata[:dmg_path])}")
  end

  private_lane :upload_github_release do
    metadata = release_metadata
    extra_assets = Array((lane_context[:SPARKLE_RELEASE_ASSETS] || [])).compact

    set_github_release(
      repository_name: ENV.fetch("RELEASE_REPOSITORY"),
      api_bearer: ENV.fetch("GITHUB_TOKEN"),
      tag_name: metadata[:tag],
      name: metadata[:release_name],
      commitish: ENV.fetch("RELEASE_COMMITISH"),
      is_draft: release_boolean_env("GITHUB_RELEASE_DRAFT"),
      is_prerelease: release_boolean_env("GITHUB_RELEASE_PRERELEASE"),
      is_generate_release_notes: true,
      upload_assets: [metadata[:zip_path], metadata[:dmg_path], *extra_assets]
    )
  end

  desc "Build the macOS release app bundle"
  lane :build do
    metadata = release_metadata
    plist_path = File.join(workspace_root, "macos", "Runner", "Info.plist")

    FileUtils.mkdir_p(metadata[:dist_dir])

    sh("cd #{shell_escape(workspace_root)} && fvm flutter pub get")
    with_restored_file(plist_path) do |restored_plist_path|
      configure_sparkle_info_plist!(restored_plist_path)

      Bundler.with_unbundled_env do
        sh("cd #{shell_escape(workspace_root)} && fvm flutter build macos --release --no-pub")
      end
    end

    UI.user_error!("Expected app bundle at #{metadata[:app_path]}") unless File.directory?(metadata[:app_path])
  end

  desc "Package the macOS release build into ZIP and DMG"
  lane :package do |options|
    build unless options[:skip_build]

    metadata = release_metadata
    FileUtils.mkdir_p(metadata[:dist_dir])
    FileUtils.rm_f([metadata[:zip_path], metadata[:dmg_path]])

    UI.user_error!("Expected app bundle at #{metadata[:app_path]}") unless File.directory?(metadata[:app_path])

    sh("ditto -c -k --sequesterRsrc --keepParent #{shell_escape(metadata[:app_path])} #{shell_escape(metadata[:zip_path])}")

    dmg_script_path = File.join(workspace_root, "scripts", "package-macos-release-dmg.sh")
    UI.user_error!("Missing DMG packaging script at #{dmg_script_path}") unless File.executable?(dmg_script_path)

    sh([
      shell_escape(dmg_script_path),
      "--app-path", shell_escape(metadata[:app_path]),
      "--output", shell_escape(metadata[:dmg_path]),
      "--app-name", shell_escape(metadata[:app_name]),
      "--volume-name", shell_escape("Install Vizor Wallet")
    ].join(" "))
  end

  desc "Install macOS signing identities and provisioning profiles via match"
  lane :sync_signing do |options|
    prepare_signing(readonly: options.fetch(:readonly, match_readonly?))
  end

  desc "Build, notarize, package, and upload the macOS release"
  lane :release do
    validate_sparkle_environment! if sparkle_enabled_for_release?
    prepare_signing(readonly: match_readonly?)
    build
    notarize_app_bundle
    package(skip_build: true)
    notarize_dmg
    lane_context[:SPARKLE_RELEASE_ASSETS] = sparkle_enabled_for_release? ? collect_sparkle_assets!(release_metadata) : []
    upload_github_release
  end
end
